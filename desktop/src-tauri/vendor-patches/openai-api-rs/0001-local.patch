+                            emitted = true;
+                        }
+                    }
+
+                    if let Some(tool_call_response) =
+                        Self::parse_tool_calls(delta).map(ChatCompletionStreamResponse::ToolCall)
+                    {
+                        self.pending_events.push_back(tool_call_response);
+                        emitted = true;
+                    }
+
+                    if emitted {
+                        return self.pending_events.pop_front();
+                    }
+                }
+            }
